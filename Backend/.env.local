# Configuration PostgreSQL LOCALE
# Utilise ce fichier pour l'entraînement local quand Neon timeout
# Copie ces lignes dans .env principal ou utilise: export $(cat .env.local | xargs)

DATABASE_URL=postgresql://localhost:5432/godmod_local

# Ou avec auth si configuré:
# DATABASE_URL=postgresql://user:password@localhost:5432/godmod_local

# Désactive les connexions externes
DB_TYPE=postgresql

# Garde les autres configs identiques
VERBOSE_MODE=False
USE_INTELLIGENCE_AMELIOREE=True
USE_SELECTION_AMELIOREE=True
API_HOST=127.0.0.1
API_PORT=8000

# Conserve tes clés API (copiées depuis .env principal)
