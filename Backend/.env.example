# Configuration PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=godmod_db
PG_USER=postgres
PG_PASSWORD=CONFIRMER

# Type de base de données (sqlite ou postgresql)
DB_TYPE=postgresql

# Autres configurations (inchangées)
VERBOSE_MODE=False
USE_INTELLIGENCE_AMELIOREE=True
USE_SELECTION_AMELIOREE=True

# Intégration IA Groq (optionnel — boost qualitatif PRISMA)
# Obtenez votre clé gratuite sur https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
