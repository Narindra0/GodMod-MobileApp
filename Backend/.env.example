# Configuration PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=godmod_db
PG_USER=postgres
PG_PASSWORD=CONFIRMER

# Type de base de données (sqlite ou postgresql)
DB_TYPE=postgresql

# Autres configurations (inchangées)
VERBOSE_MODE=False
USE_INTELLIGENCE_AMELIOREE=True
USE_SELECTION_AMELIOREE=True
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:19006,http://localhost:8000,http://127.0.0.1:19006,http://127.0.0.1:8000,http://localhost:8081,http://127.0.0.1:8081

# Intégration IA Groq (optionnel — boost qualitatif PRISMA)
# Obtenez votre clé gratuite sur https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# IA DeepSeek (NVIDIA API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2

# IA Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# IA Ollama (Local/VPS)
OLLAMA_ENABLED=True
OLLAMA_URL=http://185.77.96.180:3000
OLLAMA_MODEL=llama3:latest
OLLAMA_API_KEY=votre_cle_api_ici



# Hugging Face Deployment (Method B)
HF_TOKEN=hf_...
HF_SPACE_ID=JacknotDaniel/godmod-backend
